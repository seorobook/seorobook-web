# Copy to `.env.local` and fill in values (never commit `.env.local`).

# --- Required (Next.js + Neon DB + Neon Auth) ---

# Postgres connection string from Neon Console (pick branch: main vs meetups-mvp-scratch).
# Pooled "transaction" URI is fine. sslmode is normalized in data/db.ts.
SEORO_POSTGRES_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# If your tooling only provides DATABASE_URL, you can use this instead of SEORO_POSTGRES_URL.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Cookie signing secret for @neondatabase/auth (min 32 chars). Example:
#   openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=""

# Neon Auth base URL from Neon project → Auth (often ep-*.neonauth.<region>.aws.neon.tech).
NEON_AUTH_BASE_URL="https://ep-xxxx.neonauth.us-east-1.aws.neon.tech"

# Optional: absolute links in web (e.g. library share). Many call sites fall back to NEXT_PUBLIC_BASE_URL.
# SEORO_PUBLIC_BASE_URL="http://localhost:3000"
# Expo 웹(localhost:8081) 회원가입 시 Neon이 허용하는 callback 후보로 `Origin` 헤더가 우선됩니다.
# Neon Auth 콘솔에 신뢰 URL로 Expo 웹·Next URL을 모두 등록해 두는 것을 권장합니다.

# --- Optional ---

# Production CORS for browsers (Expo web, etc.): see `lib/api-cors.ts`.
# `http://localhost` / `127.0.0.1` (any port): allowed unless API_CORS_ALLOW_LOCALHOST=false.
# MOBILE_API_CORS_ORIGINS="https://xxxx.exp.direct"
# API_CORS_ALLOW_LOCALHOST=""

# Embedded Express backend (Socket.io, legacy). Used with `yarn dev` + backend `npm run dev`.
# SEORO_PUBLIC_BACKEND_URL="http://localhost:3001"
# NEXT_PUBLIC_BACKEND_URL="http://localhost:3001"

# Some legacy client code falls back to this.
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Protect POST /api/meetups/cleanup in production (see app/api/meetups/cleanup/route.ts).
# SEORO_CLEANUP_TOKEN=""

# Legacy visits / Agora (only if you touch those features).
# NEXT_PUBLIC_AGORA_APP_ID=""
# APP_CERTIFICATE=""
BLOB_READ_WRITE_TOKEN="blob credentials"